# Trading 212 environment
# Keep this as demo for the first 30 days.
T212_ENV=demo

# Demo API credentials only.
T212_API_KEY=
T212_API_SECRET=

# Hard safety switches.
T212_ALLOW_LIVE=false
ORDER_PLACEMENT_ENABLED=false

# Extra irreversible confirmation required for any future live mode.
# Leave blank during the 30-day trading sprint.
T212_CONFIRM_LIVE=

# Local database for paper broker / logs
TRADING_LAB_DB=./trading_lab.sqlite3
