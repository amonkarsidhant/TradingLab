# Trading 212 environment
# Keep this as demo for the first 30 days.
T212_ENV=demo

# Demo API credentials only.
# Option A: direct key/secret
T212_API_KEY=
T212_API_SECRET=

# Option B: precomputed auth header (overrides key/secret)
# T212_AUTH_HEADER="Basic $(echo -n 'key:secret' | base64)"

# Option C: account-specific pairs (for multi-account setups)
# T212_API_KEY_INVEST=
# T212_API_SECRET_INVEST=
# T212_API_KEY_STOCKS_ISA=
# T212_API_SECRET_STOCKS_ISA=

# Allow orders in pre/after-hours sessions
# T212_EXTENDED_HOURS=true

# Watcher daemon settings
# T212_WATCHER_ENABLED=true
# T212_WATCHER_INTERVAL=300            # seconds between polls (default 300)
# T212_WATCHER_AUTONOMY_TIER=1         # 1=alerts, 2=alerts+draft, 3=auto-stops

# Hard safety switches.
T212_ALLOW_LIVE=false
ORDER_PLACEMENT_ENABLED=false

# Extra confirmation required for demo non-dry-run order placement.
# Set to I_ACCEPT_DEMO_ORDER_TEST only when you are ready to test demo orders.
# Leave blank during the 30-day trading sprint.
DEMO_ORDER_CONFIRM=

# Extra irreversible confirmation required for any future live mode.
# Leave blank during the 30-day trading sprint.
T212_CONFIRM_LIVE=

# Telegram Bot Token (from @BotFather)
# Leave blank to disable the Telegram bot.
TELEGRAM_BOT_TOKEN=

# Local database for paper broker / logs
TRADING_LAB_DB=./trading_lab.sqlite3
